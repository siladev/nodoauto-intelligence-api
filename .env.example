# ─────────────────────────────────────────────────────────────────────────────
# nodoauto-intelligence-api — variables de entorno (TODOS los secretos van por env,
# nunca al repo). En Coolify se cargan como env del servicio. ADR-005 §3.
# Copiar a .env para desarrollo local. .env esta git-ignored.
# ─────────────────────────────────────────────────────────────────────────────

# Supabase — MISMA base que la PWA (fuente de verdad). El servicio escribe ai.* con
# service_role (schema OCULTO; la PWA nunca lo toca). NO usar la anon key aca.
SUPABASE_URL=https://onsclpwsspmfxitcnvld.supabase.co
SUPABASE_SERVICE_ROLE_KEY=

# Anthropic — la IA vive en el servicio (en F4 sale del env de la PWA).
ANTHROPIC_API_KEY=

# Token de servicio compartido con la PWA (auth server-to-server). La PWA lo manda
# en el header Authorization: Bearer <token>; el browser NUNCA lo conoce.
SERVICE_SHARED_TOKEN=

# HTTP
PORT=8787
NODE_ENV=development
LOG_LEVEL=info
